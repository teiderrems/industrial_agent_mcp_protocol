# Mock mode
USE_MOCK_DB=true
USE_MOCK_LLM=true

# Real DB (if USE_MOCK_DB=false)
DB_TYPE=postgresql
DB_NAME=industrial_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432


# Ordre de fallback (ex: groq, ollama, huggingface)
LLM_ORDER=mistral,gemini

# Real LLM (if USE_MOCK_LLM=false)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-pro"


# Mistral (exemple, à adapter selon les modèles disponibles)
MISTRAL_API_KEY=""
MISTRAL_MODEL="mistral-medium"   # ou mistral-small, mistral-medium, etc.

MCP_SERVER_URL=http://127.0.0.1:8000